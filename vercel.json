{
    "version": 2,
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false"
    },
    "build": {
        "env": {
            "APP_ENV": "production",
            "APP_DEBUG": "false",
            "DB_CONNECTION": "pgsql"
        },
        "buildCommand": "bash vercel-build.sh"
    }
}

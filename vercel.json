{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "composer install --no-dev --optimize-autoloader && npm install",
    "buildCommand": "npm run build",
    "builds": [
        {
            "src": "/api/index.php",
            "use": "vercel-php@0.8.0"
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt"
        },
        {
            "src": "/(.*\\.(css|js|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|map))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        
    }
}
